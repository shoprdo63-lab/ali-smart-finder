{
  "name": "GameTech Arbitrage Pro",
  "description": "Premium price comparison tool for Gaming & Tech Gadgets - Amazon to AliExpress arbitrage",
  "version": "1.0.0",
  "manifest_version": 3,
  
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "permissions": [
    "storage",
    "activeTab",
    "downloads"
  ],

  "host_permissions": [
    "https://www.amazon.com/*",
    "https://www.amazon.co.uk/*",
    "https://www.amazon.de/*",
    "https://www.amazon.ca/*",
    "https://www.amazon.fr/*",
    "https://www.amazon.it/*",
    "https://www.amazon.es/*",
    "https://www.amazon.co.jp/*",
    "https://www.amazon.in/*",
    "https://smile.amazon.com/*",
    "http://localhost:3000/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*/dp/*",
        "https://www.amazon.com/dp/*",
        "https://www.amazon.com/gp/product/*",
        "https://www.amazon.co.uk/*/dp/*",
        "https://www.amazon.co.uk/dp/*",
        "https://www.amazon.co.uk/gp/product/*",
        "https://www.amazon.de/*/dp/*",
        "https://www.amazon.de/dp/*",
        "https://www.amazon.de/gp/product/*",
        "https://www.amazon.ca/*/dp/*",
        "https://www.amazon.ca/dp/*",
        "https://www.amazon.ca/gp/product/*"
      ],
      "js": ["content-script.js"],
      "css": ["panel.css"],
      "run_at": "document_end",
      "world": "MAIN"
    }
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*", "panel.html", "panel.js"],
      "matches": ["https://www.amazon.com/*", "https://www.amazon.co.uk/*", "https://www.amazon.de/*", "https://www.amazon.ca/*"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
