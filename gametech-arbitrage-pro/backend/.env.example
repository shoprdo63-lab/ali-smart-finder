# Environment Variables Example
# Copy this file to .env and fill in your actual values

# Required - Your AliExpress Affiliate Key
# This key is stored server-side ONLY and never exposed to the client
# [cite: 2026-02-26] - Security requirement
AFFILIATE_KEY=ali_smart_finder_v1

# Optional - API Key for premium endpoints
# Used to protect admin/management endpoints
API_KEY=your-secret-api-key-here

# Optional - AliExpress API Credentials
# If you have official AliExpress API access
ALI_APP_KEY=your-aliexpress-app-key
ALI_APP_SECRET=your-aliexpress-app-secret
ALI_TRACKING_ID=your-tracking-id

# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Optional - Redis for caching
REDIS_URL=redis://localhost:6379

# Optional - Sentry for error reporting
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
