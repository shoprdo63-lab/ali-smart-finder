{
  "manifest_version": 3,
  "name": "AliSmart Finder - Gaming & Tech Price Hunter",
  "short_name": "AliSmart",
  "description": "World-class price comparison for Gaming & Tech products. Find cheaper alternatives on AliExpress instantly.",
  "version": "1.0.0",
  "author": "AliSmart Team",
  "homepage_url": "https://alismart-finder.com",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.amazon.co.uk/*",
    "https://*.amazon.de/*",
    "https://*.amazon.ca/*",
    "https://*.amazon.fr/*",
    "https://*.amazon.it/*",
    "https://*.amazon.es/*",
    "https://*.amazon.co.jp/*",
    "https://*.amazon.in/*",
    "https://*.amazon.com.au/*",
    "https://*.amazon.com.br/*",
    "https://*.amazon.com.mx/*",
    "https://*.amazon.nl/*",
    "https://*.amazon.sg/*",
    "https://ali-smart-finder.onrender.com/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "js": [
        "src/content-scripts/content.js"
      ],
      "matches": [
        "https://*.amazon.com/*",
        "https://*.amazon.co.uk/*",
        "https://*.amazon.de/*",
        "https://*.amazon.ca/*",
        "https://*.amazon.fr/*",
        "https://*.amazon.it/*",
        "https://*.amazon.es/*",
        "https://*.amazon.co.jp/*",
        "https://*.amazon.in/*",
        "https://*.amazon.com.au/*",
        "https://*.amazon.com.br/*",
        "https://*.amazon.com.mx/*",
        "https://*.amazon.nl/*",
        "https://*.amazon.sg/*"
      ],
      "css": [
        "src/content-scripts/content.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://*/*"
      ],
      "resources": [
        "icon-32.png",
        "icon-128.png"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://*.amazon.com/*",
        "https://*.amazon.co.uk/*",
        "https://*.amazon.de/*",
        "https://*.amazon.ca/*",
        "https://*.amazon.fr/*",
        "https://*.amazon.it/*",
        "https://*.amazon.es/*",
        "https://*.amazon.co.jp/*",
        "https://*.amazon.in/*",
        "https://*.amazon.com.au/*",
        "https://*.amazon.com.br/*",
        "https://*.amazon.com.mx/*",
        "https://*.amazon.nl/*",
        "https://*.amazon.sg/*"
      ],
      "resources": [
        "assets/content.ts-0457ddfa.js"
      ],
      "use_dynamic_url": true
    }
  ]
}